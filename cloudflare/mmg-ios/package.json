{
  "name": "mmg-ios-cloudflare",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "test": "node --test test/*.test.js",
    "validate:loading": "node scripts/validate-app-loading-baseline.mjs",
    "validate:renderer": "node scripts/validate-stable-renderer-v2.mjs",
    "validate:autonomy": "node scripts/validate-autonomy-controls.mjs",
    "validate:operations": "node scripts/validate-operational-routes.mjs",
    "validate:visual-preservation": "node scripts/validate-server-visual-preservation.mjs",
    "validate:production": "node scripts/validate-app-loading-baseline.mjs && node scripts/validate-stable-renderer-v2.mjs && node scripts/validate-autonomy-controls.mjs && node scripts/validate-operational-routes.mjs && node scripts/validate-server-visual-preservation.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "wrangler": "^4.24.3"
  }
}
