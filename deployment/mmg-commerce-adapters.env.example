# Non-secret shape only. Never commit real values.
MMG_COMMERCE_ENVIRONMENT=staging
MMG_COMMERCE_RELEASE_ID=release-staging-20260721-001
MMG_COMMERCE_RUNTIME_ORIGIN=https://staging-runtime.example.invalid
MMG_COMMERCE_INTERNAL_TOKEN=replace-with-secret-manager-value-minimum-32-characters
MMG_COMMERCE_REQUEST_TIMEOUT_MS=8000

# Optional. Omit to use the canonical route manifest.
MMG_COMMERCE_ROUTE_PROBE_PATHS=/api/internal/commerce/deployment,/api/internal/commerce/operations,/api/admin/commerce/operations,/api/internal/commerce/rehearsal,/api/internal/commerce/rehearsal/adapter,/api/internal/runtime-controls/control,/api/internal/runtime-controls/rollout

# HTTPS destinations only. Store the real value in the deployment secret manager.
MMG_COMMERCE_ALERT_DESTINATIONS=on_call_pager=https://alerts.example.invalid/pager,operations_email=https://alerts.example.invalid/email,operations_chat=https://alerts.example.invalid/chat,executive_briefing=https://alerts.example.invalid/executive

# Workflow secrets configured in the mmg-commerce-staging GitHub Environment.
MMG_COMMERCE_REHEARSAL_ENDPOINT=https://staging-runtime.example.invalid/api/internal/commerce/rehearsal
MMG_COMMERCE_REHEARSAL_TOKEN=replace-with-separate-staging-rehearsal-secret

# Provider-managed secrets not represented by literal values here:
# DATABASE_URL
# SHOPIFY_ADMIN_ACCESS_TOKEN
# SHOPIFY_API_SECRET
# STORAGE_SIGNING_KEY
# ALERT_PROVIDER_CREDENTIALS
# ADMIN_SESSION_SIGNING_SECRET
