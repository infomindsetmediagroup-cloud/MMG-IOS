# Non-secret MMG commerce staging integration environment contract.
# Store every credential value in Cloudflare Workers or the protected GitHub Environment.

MMG_COMMERCE_ENVIRONMENT=staging
MMG_COMMERCE_RELEASE_ID=release-staging-YYYYMMDD-001
MMG_COMMERCE_RELEASE_COMMIT_SHA=0000000000000000000000000000000000000000
MMG_COMMERCE_RUNTIME_ORIGIN=https://mmg-commerce-staging.example.workers.dev
MMG_COMMERCE_STAGING_RUNTIME_ORIGIN=https://mmg-commerce-staging.example.workers.dev
MMG_COMMERCE_REQUEST_TIMEOUT_MS=8000
MMG_COMMERCE_MONITOR_ENABLED=false
MMG_GITHUB_ENVIRONMENT_NAME=mmg-commerce-staging

# Cloudflare deployment configuration. Keep IDs and credentials in the protected
# GitHub Environment. Hyperdrive carries the database connection string to the Worker.
# The upstream service must be a staging-only Worker name ending in -staging.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
MMG_CLOUDFLARE_STAGING_HYPERDRIVE_ID=
MMG_CLOUDFLARE_STAGING_UPSTREAM_SERVICE=mmg-commerce-api-staging

# Runtime credentials. Every value must be at least 32 characters. Operations,
# rehearsal, adapter, runtime-control, integration, Admin, and provider credentials
# must remain separate. Never commit real values.
MMG_COMMERCE_STAGING_OPERATIONS_TOKEN=
MMG_COMMERCE_STAGING_REHEARSAL_TOKEN=
MMG_COMMERCE_STAGING_REHEARSAL_ADAPTER_TOKEN=
MMG_COMMERCE_STAGING_RUNTIME_CONTROL_TOKEN=
MMG_COMMERCE_STAGING_INTEGRATION_TOKEN=
MMG_COMMERCE_STAGING_ADMIN_DASHBOARD_TOKEN=
MMG_COMMERCE_STAGING_PROVIDER_HEALTH_TOKEN=

# PostgreSQL is used by the migration and release-registration workflows. The
# deployed Worker uses the HYPERDRIVE binding rather than receiving this URL.
MMG_COMMERCE_STAGING_DATABASE_URL=
MMG_COMMERCE_STAGING_READINESS_ENDPOINT=https://mmg-commerce-staging.example.workers.dev/api/internal/commerce/staging-readiness
MMG_COMMERCE_STAGING_INTEGRATION_ENDPOINT=https://mmg-commerce-staging.example.workers.dev/api/internal/commerce/staging-integration
MMG_COMMERCE_REHEARSAL_ENDPOINT=https://mmg-commerce-staging.example.workers.dev/api/internal/commerce/rehearsal

# Alert destinations are comma-separated channel=https://endpoint entries.
# Use nonproduction providers for the staging rehearsal.
MMG_COMMERCE_ALERT_ENVIRONMENT=staging
MMG_COMMERCE_ALERT_DESTINATIONS=on_call_pager=https://alerts.example.com/staging-pager,operations_email=https://alerts.example.com/staging-email,operations_chat=https://alerts.example.com/staging-chat,executive_briefing=https://alerts.example.com/staging-executive

# Exact-release provider health endpoints. Each endpoint must return 2xx and
# identify the requested release through JSON `releaseId` or X-MMG-Release-Id.
MMG_COMMERCE_ALERT_HEALTH_ENDPOINT=https://alerts.example.com/health
MMG_COMMERCE_SCHEDULER_HEALTH_ENDPOINT=https://scheduler.example.com/health
MMG_COMMERCE_DISPATCHER_HEALTH_ENDPOINT=https://dispatcher.example.com/health
MMG_COMMERCE_STORAGE_SIGNER_HEALTH_ENDPOINT=https://storage-signer.example.com/health

# Explicit readiness declarations. Set true only after the provider is connected
# and capable of writing a fresh exact-release heartbeat.
MMG_COMMERCE_ADMIN_AUTH_CONFIGURED=false
MMG_COMMERCE_SCHEDULER_CONFIGURED=false
MMG_COMMERCE_DISPATCHER_CONFIGURED=false
MMG_COMMERCE_STORAGE_SIGNER_CONFIGURED=false

# Optional comma-separated route override. The canonical default includes the
# staging-readiness, staging-integration, provider-heartbeat, operations,
# rehearsal, runtime-control, Customer Portal, Knowledge Library, Thank-you,
# webhook, and deployment endpoints.
MMG_COMMERCE_ROUTE_PROBE_PATHS=

# The following host adapters must write exact-release healthy heartbeats before
# staging verification can pass: database, runtime_routes, runtime_controls,
# alerts, scheduler, dispatcher, storage_signer, admin_auth.
