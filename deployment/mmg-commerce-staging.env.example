# Non-secret MMG commerce staging integration environment contract.
# Store all credential values in the deployment platform or GitHub Environment.

MMG_COMMERCE_ENVIRONMENT=staging
MMG_COMMERCE_RELEASE_ID=release-staging-YYYYMMDD-001
MMG_COMMERCE_RELEASE_COMMIT_SHA=0000000000000000000000000000000000000000
MMG_COMMERCE_RUNTIME_ORIGIN=https://staging-runtime.example.com
MMG_COMMERCE_STAGING_RUNTIME_ORIGIN=https://staging-runtime.example.com
MMG_COMMERCE_REQUEST_TIMEOUT_MS=8000
MMG_GITHUB_ENVIRONMENT_NAME=mmg-commerce-staging

# Runtime credentials. Each value must be at least 32 characters and all five
# values must be distinct. Never commit real values.
MMG_COMMERCE_STAGING_OPERATIONS_TOKEN=
MMG_COMMERCE_STAGING_REHEARSAL_TOKEN=
MMG_COMMERCE_STAGING_REHEARSAL_ADAPTER_TOKEN=
MMG_COMMERCE_STAGING_RUNTIME_CONTROL_TOKEN=
MMG_COMMERCE_STAGING_INTEGRATION_TOKEN=

# PostgreSQL and protected workflow endpoints. Configure as secrets.
MMG_COMMERCE_STAGING_DATABASE_URL=
MMG_COMMERCE_STAGING_READINESS_ENDPOINT=https://staging-runtime.example.com/api/internal/commerce/staging-readiness
MMG_COMMERCE_STAGING_INTEGRATION_ENDPOINT=https://staging-runtime.example.com/api/internal/commerce/staging-integration
MMG_COMMERCE_REHEARSAL_ENDPOINT=https://staging-runtime.example.com/api/internal/commerce/rehearsal

# Alert destinations are comma-separated channel=https://endpoint entries.
# Use nonproduction providers for the staging rehearsal.
MMG_COMMERCE_ALERT_ENVIRONMENT=staging
MMG_COMMERCE_ALERT_DESTINATIONS=on_call_pager=https://alerts.example.com/staging-pager,operations_email=https://alerts.example.com/staging-email,operations_chat=https://alerts.example.com/staging-chat,executive_briefing=https://alerts.example.com/staging-executive

# Explicit readiness declarations. Set true only after the provider is connected
# and capable of writing a fresh exact-release heartbeat.
MMG_COMMERCE_ADMIN_AUTH_CONFIGURED=false
MMG_COMMERCE_SCHEDULER_CONFIGURED=false
MMG_COMMERCE_DISPATCHER_CONFIGURED=false
MMG_COMMERCE_STORAGE_SIGNER_CONFIGURED=false

# Optional comma-separated route override. The canonical default includes the
# staging-readiness, staging-integration, operations, rehearsal, runtime-control,
# Customer Portal, Knowledge Library, Thank-you, webhook, and deployment routes.
MMG_COMMERCE_ROUTE_PROBE_PATHS=

# The following host adapters must write exact-release healthy heartbeats before
# staging verification can pass: database, runtime_routes, runtime_controls,
# alerts, scheduler, dispatcher, storage_signer, admin_auth.
