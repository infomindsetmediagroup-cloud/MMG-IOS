# Non-secret MMG commerce operations configuration contract.
# Secrets must be configured in the owning runtime or protected GitHub Environment.

MMG_COMMERCE_OPERATIONS_ENABLED=false
MMG_COMMERCE_MONITOR_ENABLED=false
MMG_COMMERCE_MONITOR_INTERVAL_SECONDS=900
MMG_COMMERCE_ACTIVE_RELEASE_ID=
MMG_COMMERCE_CANONICAL_SHOP_DOMAIN=
MMG_COMMERCE_OPERATIONS_ALLOWED_ORIGIN=
MMG_COMMERCE_ROLLOUT_STAGE=paused
MMG_COMMERCE_ROLLOUT_RELEASE_SALT_VERSION=1
MMG_COMMERCE_E2E_MAX_AGE_SECONDS=86400
MMG_COMMERCE_SIGNED_ACCESS_TTL_SECONDS=300

# Required secret names, values intentionally omitted:
# MMG_COMMERCE_OPERATIONS_TOKEN
# DATABASE_URL
# SHOPIFY_ADMIN_ACCESS_TOKEN
# SHOPIFY_APP_SECRET
# MMG_COMMERCE_ROLLOUT_RELEASE_SALT
# MMG_STORAGE_SIGNING_KEY
# MMG_DISPATCHER_SECRET
# MMG_ALERT_PROVIDER_TOKEN
# MMG_ALERT_DESTINATION
