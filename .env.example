# Server-only provider credential. Never place this value in iOS build settings.
OPENAI_API_KEY=

# Explicit production model selected by the deployment owner.
OPENAI_MODEL=

# Revocable gateway token shared with the current trusted client build.
# This is not an OpenAI credential and must be rotated if exposed.
KAIROS_RUNTIME_TOKEN=
SHOPIFY_STORE_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-07

# Shopify AI Toolkit and CLI privacy controls.
OPT_OUT_INSTRUMENTATION=true
SHOPIFY_CLI_NO_ANALYTICS=1

# Governed Shopify store targets. Staging must never equal production.
MMG_SHOPIFY_STAGING_STORE=
MMG_SHOPIFY_PRODUCTION_STORE=mindsetmediagroup.myshopify.com

# Mutation controls are closed by default and opened only for an approved execution window.
MMG_SHOPIFY_ALLOW_MUTATIONS=false
MMG_SHOPIFY_PRODUCTION_APPROVED=false
MMG_SHOPIFY_RECEIPT_DIR=reports/shopify-operations
