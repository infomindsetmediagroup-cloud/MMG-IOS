{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/kairos.ts": {
      "maxDuration": 60
    },
    "api/actions.ts": {
      "maxDuration": 30
    },
    "api/theme-plan.ts": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/api/kairos",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/api/theme-plan",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
