# Never commit real values. Copy this file to .env on the private GPU host.
KAIROS_INFERENCE_TOKEN=replace-with-a-long-random-secret
KAIROS_TENSOR_PARALLEL_SIZE=1
KAIROS_GPU_MEMORY_UTILIZATION=0.90
KAIROS_MAX_MODEL_LEN=32768
KAIROS_MAX_NUM_SEQS=8

# Optional when the selected model repository requires authentication.
HUGGING_FACE_HUB_TOKEN=

# Cloudflare Worker production secrets/variables:
# KAIROS_INFERENCE_URL=https://inference.your-private-domain.example
# KAIROS_INFERENCE_TOKEN=<same value as above>
# KAIROS_MODEL=Qwen3.6-35B-A3B
# KAIROS_INFERENCE_TIMEOUT_MS=180000
