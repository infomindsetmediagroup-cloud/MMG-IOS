# Kairos Web Admin local configuration
# Copy to .env when running locally. Do not commit .env.

# Local operator
KAIROS_LOCAL_PORT=4100
KAIROS_LOCAL_DATA_FILE=.kairos/local-operator-state.json

# Shopify live transition
SHOPIFY_STORE_DOMAIN=mindsetmediagroup.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2026-04

# Future database-backed mode
DATABASE_URL=

# Future auth-backed mode
KAIROS_ADMIN_EMAIL=
KAIROS_SESSION_SECRET=
