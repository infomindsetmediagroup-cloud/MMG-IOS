{
  "name": "mmg-kairos-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate:shopify": "node scripts/validate-shopify-governance.mjs",
    "validate:service-product": "node shopify/products/professional-cover-design-service/validate.mjs",
    "check": "npm run typecheck && npm test && npm run validate:shopify && npm run validate:service-product",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.24.3"
  }
}
