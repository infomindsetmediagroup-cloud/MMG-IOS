{
  "name": "mmg-kairos-runtime",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "shopify:toolkit:install": "node scripts/shopify-ai-toolkit-install.mjs",
    "shopify:toolkit:doctor": "node scripts/shopify-ai-toolkit-doctor.mjs",
    "shopify:toolkit:policy": "node scripts/shopify-ai-toolkit-policy.mjs",
    "shopify:store:execute": "node scripts/shopify-store-execute.mjs",
    "check": "npm run shopify:toolkit:policy && npm run typecheck && npm test",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.24.3"
  }
}
